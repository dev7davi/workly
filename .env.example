# Este é um exemplo seguro do .env
# Não versione o .env original contendo essas senhas.
# Copie este arquivo para .env no servidor/vps e preencha-o.

# A URL da sua API do Supabase
VITE_SUPABASE_URL=https://sua-url-do-supabase-aqui.supabase.co

# A Chave Pública (Anon/Public Key) gerada no painel Supabase > API
VITE_SUPABASE_ANON_KEY=sua-chave-anonima-aqui

# (Opcional - backend only) Chaves restritas de Serviço NUNCA devem ir para o VITE_ do frontend
# SUPABASE_SERVICE_ROLE_KEY=sua-chave-secreta
